# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# === Google Cloud Deployment & Automatic Update Strategy ===
# APP_VERSION: Defines the current release version of the application (e.g. 1.2.0)
APP_VERSION="1.1.2"

# APP_ENV: Defines the target hosting environment (Staging or Production)
APP_ENV="Staging"

# BUILD_NUM: Unique identifier of the deployment artifact build (e.g. 1024)
BUILD_NUM="101"

# COMMIT_SHA: Git commit/revision hash representing this build instance (e.g. 7c3b21a)
COMMIT_SHA="dev-rev"

# UPDATE_POLLING_INTERVAL: Polling interval (in ms) for update detection. 
# Defaults to 300000 (5 mins) in Production, and 4000 (4 seconds) in Staging.
UPDATE_POLLING_INTERVAL="300000"

# ALLOW_LEGACY_AUTH: Enable fallback headers x-user-role and x-user-id in production/staging (disabled by default)
ALLOW_LEGACY_AUTH=false
